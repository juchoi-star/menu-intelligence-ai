# === Menu Intelligence AI - Backend 환경변수 ===
# 이 파일을 .env 로 복사해 사용하세요.

APP_NAME=Menu Intelligence AI
DEBUG=false

# 프론트엔드 오리진(CORS). 콤마로 여러 개 지정 가능(JSON 배열도 허용).
# 예) CORS_ORIGINS=https://menu.vercel.app,https://staging.vercel.app
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# 미설정 시 로컬 SQLite 로 자동 폴백(로컬 실행용).
# 클라우드 배포 시 Supabase/Render 연결 문자열을 넣으면 됩니다
# (postgres:// , postgresql:// 스킴은 자동으로 +psycopg2 로 정규화).
#   Supabase 예: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=sqlite:///./menu_intelligence.db

# --- OpenAI (선택) ---
# 미설정 시 규칙 기반(rule-based) 내러티브로 동작.
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- 업로드 제한 ---
MAX_UPLOAD_MB=20
